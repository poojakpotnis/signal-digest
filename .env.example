# Google OAuth2 (Auth.js v5 auto-detects these names for the Google provider)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret
# Auth.js session encryption key (generate with: npx auth secret)
AUTH_SECRET=generate-with-npx-auth-secret
# Single authorized email address
ALLOWED_EMAIL=your-email@gmail.com
# n8n webhook URL
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/your-webhook-id
# n8n follow-up webhook URL for personal post Q&A flow
N8N_FOLLOWUP_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/your-followup-webhook-id
# Anthropic API key for Claude AI generation
ANTHROPIC_API_KEY=your-anthropic-api-key
# Tavily API key for web search
TAVILY_API_KEY=your-tavily-api-key
